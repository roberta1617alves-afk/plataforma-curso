# ── Supabase ──────────────────────────────────────────
# Encontre em: supabase.com → seu projeto → Settings → API
SUPABASE_URL=https://SEU-PROJETO.supabase.co
SUPABASE_SERVICE_KEY=eyJ...  # chave "service_role" (secreta!)

# ── Resend ────────────────────────────────────────────
# Encontre em: resend.com → API Keys
RESEND_API_KEY=re_...

# ── Configurações do seu curso ────────────────────────
COURSE_NAME=Nome do Seu Curso
SITE_URL=https://seu-site.vercel.app

# E-mail remetente (precisa ser um domínio verificado no Resend,
# ou use "onboarding@resend.dev" para testes)
FROM_EMAIL=contato@seudominio.com.br

# ── Segurança do Webhook ──────────────────────────────
# Coloque qualquer texto secreto aqui e também na Kiwify
KIWIFY_WEBHOOK_TOKEN=coloque-um-texto-secreto-aqui
